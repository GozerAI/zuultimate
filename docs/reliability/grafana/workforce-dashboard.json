{
  "__inputs": [],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "PoP Availability",
      "description": "Rate of PoP authentication attempts (success vs failure)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum(rate(pop_auth_total{status=\"success\"}[$__rate_interval]))",
          "legendFormat": "Success",
          "refId": "A"
        },
        {
          "expr": "sum(rate(pop_auth_total{status=\"failure\"}[$__rate_interval]))",
          "legendFormat": "Failure",
          "refId": "B"
        },
        {
          "expr": "sum(rate(pop_auth_total{status=\"success\"}[$__rate_interval])) / clamp_min(sum(rate(pop_auth_total[$__rate_interval])), 1)",
          "legendFormat": "Success Rate",
          "refId": "C"
        }
      ]
    },
    {
      "id": 2,
      "title": "Auth by PoP Region",
      "description": "Authentication attempts stacked by region",
      "type": "barchart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "stacking": { "mode": "normal" }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" },
        "orientation": "vertical",
        "barWidth": 0.8
      },
      "targets": [
        {
          "expr": "sum by (region) (increase(pop_auth_total[$__range]))",
          "legendFormat": "{{ region }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Certificate Outcomes",
      "description": "Distribution of certificate validation results",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "valid" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "expired" },
            "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "revoked" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "invalid_chain" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "tooltip": { "mode": "single" },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "sum by (result) (increase(pop_cert_validations_total[$__range]))",
          "legendFormat": "{{ result }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Posture Outcomes",
      "description": "Distribution of device posture check results",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "pass" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "fail" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "step_up" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "tooltip": { "mode": "single" },
        "pieType": "donut",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "targets": [
        {
          "expr": "sum by (result) (increase(pop_posture_checks_total[$__range]))",
          "legendFormat": "{{ result }}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "JIT Grants",
      "description": "Just-in-time access grants over time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Requested" },
            "properties": [{ "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Approved" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Revoked" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum(increase(zuul_jit_grants_total{action=\"requested\"}[$__rate_interval]))",
          "legendFormat": "Requested",
          "refId": "A"
        },
        {
          "expr": "sum(increase(zuul_jit_grants_total{action=\"approved\"}[$__rate_interval]))",
          "legendFormat": "Approved",
          "refId": "B"
        },
        {
          "expr": "sum(increase(zuul_jit_grants_total{action=\"revoked\"}[$__rate_interval]))",
          "legendFormat": "Revoked",
          "refId": "C"
        }
      ]
    },
    {
      "id": 6,
      "title": "Break Glass Sessions",
      "description": "Emergency break-glass session lifecycle",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Initiated" },
            "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Activated" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "Deactivated" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "sum(increase(zuul_break_glass_total{action=\"initiated\"}[$__rate_interval]))",
          "legendFormat": "Initiated",
          "refId": "A"
        },
        {
          "expr": "sum(increase(zuul_break_glass_total{action=\"activated\"}[$__rate_interval]))",
          "legendFormat": "Activated",
          "refId": "B"
        },
        {
          "expr": "sum(increase(zuul_break_glass_total{action=\"deactivated\"}[$__rate_interval]))",
          "legendFormat": "Deactivated",
          "refId": "C"
        }
      ]
    },
    {
      "id": 7,
      "title": "Sovereignty Violations",
      "description": "Count of data sovereignty policy violations",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "textMode": "value_and_name",
        "reduceOptions": { "calcs": ["sum"] }
      },
      "targets": [
        {
          "expr": "sum(increase(zuul_sovereignty_violations_total[$__range]))",
          "legendFormat": "Violations",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "CRL Freshness",
      "description": "Age of cached CRL per region (lower is better)",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 600 },
              { "color": "red", "value": 900 }
            ]
          },
          "min": 0,
          "max": 1200,
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "crl_age_seconds",
          "legendFormat": "{{ region }}",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["zuultimate", "workforce", "pop", "zero-trust"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(pop_auth_total, region)",
        "name": "region",
        "label": "Region",
        "type": "query",
        "refresh": 2,
        "multi": true,
        "includeAll": true
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "utc",
  "title": "Zuultimate Workforce Dashboard",
  "uid": "zuul-workforce-001",
  "version": 1
}
